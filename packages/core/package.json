{
  "name": "@graffiticode/l0013",
  "version": "0.1.0",
  "description": "L0013 — a Graffiticode dialect that renders a task's form view to an image (`snap`), inheriting @graffiticode/l0000",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./spec/*": "./spec/*"
  },
  "files": [
    "dist",
    "spec"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build-static": "node tools/build-static.js",
    "lint": "eslint src tools"
  },
  "dependencies": {
    "@graffiticode/l0000": "^0.1.1",
    "firebase-admin": "^12.7.0",
    "puppeteer": "^23.11.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "spec-md": "^3.1.0"
  }
}
